# Required: GitHub Personal Access Token with org:read and repo scope
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Optional: GitHub API base URL (default: https://api.github.com)
# GITHUB_API_BASE_URL=https://api.github.com

# Optional: Maximum concurrent API requests (default: 10)
# GITHUB_API_MAX_CONCURRENCY=10

# Optional: Items per page for GitHub pagination (default: 100, max: 100)
# GITHUB_API_PER_PAGE=100
